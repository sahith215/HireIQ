# =============================================================
# HireIQ Frontend — Environment Variable Template
# Copy this file to .env and fill in the actual values.
# DO NOT put real credentials in this file.
# =============================================================

# Supabase project URL (found in Supabase → Settings → API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key (found in Supabase → Settings → API)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# API key expected by your n8n webhook (set this in n8n header auth)
VITE_API_KEY=your_api_key_here

# Public URL of your n8n instance (used for health checks & webhooks in production)
# In development this defaults to http://localhost:5678
VITE_N8N_URL=https://your-n8n-instance.com
